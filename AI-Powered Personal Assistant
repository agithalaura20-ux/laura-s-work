from assistant.core import Assistant

def main():
    assistant = Assistant()
    print("Hello! I am your AI Assistant. Say 'quit' to exit.")
    while True:
        query = input("You: ")
        if query.lower() == "quit":
            break
        response = assistant.respond(query)
        print(f"Assistant: {response}")

if __name__ == "__main__":
    main()

from assistant.skills import weather, news, joke
from assistant.voice import speak, listen

class Assistant:
    def __init__(self):
        self.skills = {
            "weather": weather.get_weather,
            "news": news.get_news,
            "joke": joke.get_joke
        }

    def respond(self, text):
        text = text.lower()
        # Voice option: speak response
        if "weather" in text:
            answer = self.skills["weather"]()
        elif "news" in text:
            answer = self.skills["news"]()
        elif "joke" in text:
            answer = self.skills["joke"]()
        else:
            answer = "Sorry, I can't answer that yet 😅"
        speak(answer)
        return answer

import pyttsx3

# Initialize TTS engine
engine = pyttsx3.init()

def speak(text):
