import requests

def get_weather():
    # Example: OpenWeatherMap API (replace YOUR_API_KEY)
    api_key = "YOUR_API_KEY"
    city = "London"
    url = f"http://api.openweathermap.org/data/2.5/weather?q={city}&appid={api_key}&units=metric"
    try:
        response = requests.get(url).json()
        temp = response['main']['temp']
        desc = response['weather'][0]['description']
        return f"The weather in {city} is {desc}, {temp}°C 🌤️"
    except:
        return "Sorry, I can't fetch the weather right now."


import requests

def get_news():
    # Example: NewsAPI (replace YOUR_API_KEY)
    api_key = "YOUR_API_KEY"
    url = f"https://newsapi.org/v2/top-headlines?country=us&apiKey={api_key}"
    try:
        articles = requests.get(url).json()['articles'][:3]
        news_text = "\n".join([f"- {a['title']}" for a in articles])
        return f"Top news:\n{news_text}"
    except:
        return "Sorry, I can't fetch news right now."

